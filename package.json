{
  "name": "multibotv1",
  "version": "1.0.0",
  "description": "MultiBot V1",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc --skipLibCheck && mkdir -p dist/locales && cp -r src/locales/* dist/locales/",
    "start": "node prestart.js && node dist/index.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.53",
    "axios": "^1.7.2",
    "chess.js": "^1.4.0",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "node-sqlite3-wasm": "^0.8.57",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}