# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# ── Optional but recommended ───────────────────────────────────────────────────
# Your Discord user ID. Grants owner-only access to /deploy.
BOT_OWNER_ID=your_discord_user_id_here

# ── DB-Sync (GitHub backup) — required for automatic backup push (every ─────
#    15 min + on shutdown) and restore on boot on Render's free tier.
# Create a PRIVATE GitHub repo and a Personal Access Token (Contents: Read+Write)
# See src/services/dbSync.ts for full setup instructions.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
GITHUB_REPO=yourusername/bot-db-backup
GITHUB_BRANCH=main

# ── Database path (optional) ──────────────────────────────────────────────────
# Default: ./bot.db  — only change if you know what you're doing
# DB_PATH=/custom/path/bot.db
